# Copy this file to .env and fill in your local values.
# The .env file is git-ignored and loaded automatically by spring-dotenv.

# PostgreSQL (your app data — pages, projects, etc.)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/creative
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Supabase JWT issuer for Spring Security
# Find in: Supabase Dashboard → Project Settings → API → JWT Settings
# Format: https://YOUR_PROJECT_REF.supabase.co/auth/v1
SUPABASE_JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1

# Optional: first user with this email is promoted to admin on first sync
BOOTSTRAP_ADMIN_EMAIL=admin@platform.io

# Media metadata is stored in Postgres (Flyway V4 media_assets).
# Binary files live in Supabase Storage bucket "media" (configured on the frontend).
