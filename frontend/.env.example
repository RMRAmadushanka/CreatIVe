# Spring Boot API (local)
VITE_API_URL=http://localhost:8080

# Supabase — Project Settings → API
# URL looks like: https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use the "anon" "public" key (safe for browser)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Media library uses Supabase Storage bucket name: media (public).
# In Supabase Dashboard → Storage → New bucket → name "media", Public: ON.
# Then Storage → Policies (or SQL editor), e.g.:
#
#   create policy "Public read media"
#     on storage.objects for select
#     using (bucket_id = 'media');
#
#   create policy "Auth upload media"
#     on storage.objects for insert
#     with check (
#       bucket_id = 'media'
#       and auth.role() = 'authenticated'
#       and (storage.foldername(name))[1] = auth.uid()::text
#     );
#
#   create policy "Auth update own media"
#     on storage.objects for update
#     using (
#       bucket_id = 'media'
#       and auth.uid()::text = (storage.foldername(name))[1]
#     );
#
#   create policy "Auth delete own media"
#     on storage.objects for delete
#     using (
#       bucket_id = 'media'
#       and auth.uid()::text = (storage.foldername(name))[1]
#     );
